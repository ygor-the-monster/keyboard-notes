{
  "name": "keyboard-notes",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A practice notebook for people learning an instrument: notes, engraved staves you can hear, chord charts, recordings, and sheet-music PDFs in one lesson.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "icons:maskable": "node scripts/generate-maskable-icon.mjs",
    "icons:shortcuts": "node scripts/generate-shortcut-icons.mjs",
    "assets": "npm run icons:maskable && npm run icons:shortcuts && npm run fonts:build",
    "screenshots": "vite build && node scripts/generate-tool-screenshots.mjs",
    "fonts:fetch": "node scripts/fetch-font-originals.mjs",
    "fonts:build": "node scripts/build-fonts.mjs",
    "kb:index": "node scripts/build-kb-index.mjs",
    "preview": "vite preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:types": "vitest run --project types",
    "test:watch": "vitest --project unit",
    "coverage": "vitest run --coverage",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "abcjs": "^6.4.3",
    "marked": "^18.0.5",
    "marked-footnote": "^1.4.0",
    "marked-smartypants": "^1.1.12",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "pitchy": "^4.1.0",
    "react": "^19.2.7",
    "react-aria": "^3.50.0",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@react-aria/optimize-locales-plugin": "^2.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260619.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "playwright": "^1.61.0",
    "subset-font": "^2.5.0",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
