{
  "name": "piano-notes",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Jupyter-style notebook for piano lessons: Markdown + ABC music notation with playback and MIDI input.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:types": "vitest run --project types",
    "test:watch": "vitest --project unit",
    "coverage": "vitest run --coverage",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@react-spectrum/s2": "^1.4.0",
    "abcjs": "^6.4.3",
    "marked": "^12.0.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "pitchy": "^4.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@react-aria/optimize-locales-plugin": "^1.2.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260618.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "playwright": "^1.61.0",
    "unplugin-parcel-macros": "^0.2.0",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
