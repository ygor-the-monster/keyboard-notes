{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["react", "import"],
  "env": { "browser": true, "es2024": true },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "eqeqeq": ["warn", "smart"]
  },
  "ignorePatterns": ["dist", "node_modules", "storybook-static"]
}
