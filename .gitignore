# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
dev-dist/
*.tsbuildinfo

# Generated assets — rebuilt from their committed sources by `npm run assets` (the prepare
# lifecycle runs it on install + in CI). Sources stay tracked: fonts/ originals, public/icons/
# icon-fg.png + icon-bg.png, the hand-authored SVGs, public/icon-detailed.png, and the
# public/screenshots (lesson shots hand-captured; tool shots committed by choice).
/public/fonts/
/public/icons/maskable-icon-*.png
/public/icons/shortcut-*.png

# Test / coverage
coverage/
.vitest/
playwright-report/
test-results/
.playwright-mcp/

# Lighthouse CI output. CI uploads to temporary-public-storage; a local
# `--upload.target=filesystem` run drops these in the repo root.
.lighthouseci/
*.report.html
*.report.json
/manifest.json

# Vitest browser-mode failure screenshots (ephemeral; regenerated each run).
# Visual-regression baselines live in __screenshots__/ and stay tracked.
.vitest-attachments/

# Vite / tooling caches
.vite/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
